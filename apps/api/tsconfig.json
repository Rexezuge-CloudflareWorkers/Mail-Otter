{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "types": ["@cloudflare/workers-types"],
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@mail-otter/shared": ["../../packages/shared/src"],
      "@mail-otter/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["cloudflare-env.d.ts", "src/**/*.ts"],
  "exclude": ["test", "node_modules"]
}
